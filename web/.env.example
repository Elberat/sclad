# Base example for local development.
# If you want separate dev/prod databases, prefer:
# - .env.development.local
# - .env.production.local
#
# Vite will automatically load the file based on `--mode`.

# Optional label for debugging.
VITE_APP_ENV=development

# Supabase project URL.
# Find it in Supabase Dashboard -> Project Settings -> API -> Project URL.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key.
# Find it in Supabase Dashboard -> Project Settings -> API -> Project API keys -> anon public.
# This key is safe for frontend usage when Row Level Security policies are configured.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Do not put SUPABASE_SERVICE_ROLE_KEY here.
# Vite exposes VITE_* variables to the browser bundle, so service-role/admin keys must stay server-side only.
